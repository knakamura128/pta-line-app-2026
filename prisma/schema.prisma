generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum SurveyStatus {
  DRAFT
  PUBLISHED
  CLOSED
}

enum SelectionInputType {
  NONE
  RADIO
  CHECKBOX
}

enum MessageDeliveryKind {
  RECEIPT
  CONFIRMATION
}

enum MessageDeliveryStatus {
  SENT
  FAILED
}

model Survey {
  id          String        @id @default(cuid())
  slug        String        @unique
  title       String
  committee   String
  description String
  workDetails String        @default("")
  confirmationMessage String @default("")
  selectionTitle String?
  selectionType SelectionInputType @default(NONE)
  selectionOptions String[] @default([])
  selectionOptionLimits Int[] @default([])
  useDateRange Boolean      @default(false)
  eventStartDate DateTime?
  eventEndDate DateTime?
  eventStartTime String?
  eventEndTime String?
  startsAt    DateTime
  endsAt      DateTime
  closeAt     DateTime
  capacity    Int
  status      SurveyStatus  @default(PUBLISHED)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  applications Application[]
  messageDeliveries MessageDelivery[]
}

model Application {
  id          String   @id @default(cuid())
  surveyId    String
  lineUserId  String
  familyName  String   @default("")
  displayName String
  childGrade  String
  childClass  String
  selectionAnswers String[] @default([])
  note        String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  survey      Survey   @relation(fields: [surveyId], references: [id], onDelete: Cascade)
  messageDeliveries MessageDelivery[]

  @@unique([surveyId, lineUserId])
}

model MessageDelivery {
  id            String                @id @default(cuid())
  surveyId      String
  applicationId String?
  lineUserId    String
  kind          MessageDeliveryKind
  status        MessageDeliveryStatus
  messageBody   String
  errorMessage  String?
  sentAt        DateTime?
  createdAt     DateTime              @default(now())
  survey        Survey                @relation(fields: [surveyId], references: [id], onDelete: Cascade)
  application   Application?          @relation(fields: [applicationId], references: [id], onDelete: SetNull)

  @@index([surveyId, kind, status])
  @@index([applicationId, kind])
}
